{
  "name": "frontend",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "ng": "ng",
    "tailwind": "tailwindcss --input src/styles.css --output src/styles.tailwind.css",
    "tailwind:watch": "tailwindcss --input src/styles.css --output src/styles.tailwind.css --watch",
    "start": "npm run tailwind && concurrently -k \"npm run tailwind:watch\" \"ng serve\"",
    "build": "npm run tailwind && ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.{ts,html,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,json}\"",
    "typecheck": "tsc --noEmit"
  },
  "private": true,
  "dependencies": {
    "@angular/cdk": "^19.2.19",
    "@angular/common": "^19.2.21",
    "@angular/compiler": "^19.2.0",
    "@angular/core": "^19.2.0",
    "@angular/forms": "^19.2.0",
    "@angular/platform-browser": "^19.2.0",
    "@angular/platform-browser-dynamic": "^19.2.0",
    "@angular/router": "^19.2.0",
    "@microsoft/signalr": "^10.0.0",
    "@primeng/themes": "^21.0.4",
    "@tailwindcss/cli": "^4.3.0",
    "@tailwindcss/postcss": "^4.3.0",
    "echarts": "^6.0.0",
    "gsap": "^3.15.0",
    "postcss": "^8.5.14",
    "primeicons": "^7.0.0",
    "primeng": "^19.1.4",
    "rxjs": "~7.8.0",
    "tailwindcss": "^4.3.0",
    "tslib": "^2.3.0",
    "xlsx": "^0.18.5",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.2.25",
    "@angular/cli": "^19.2.25",
    "@angular/compiler-cli": "^19.2.0",
    "@types/eslint__js": "^8.42.3",
    "@types/jasmine": "~5.1.0",
    "concurrently": "^9.1.2",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "jasmine-core": "~5.6.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "prettier": "^3.5.0",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.0.0"
  }
}
